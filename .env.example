# Environment variables for docker-compose
# Copy this file to .env and fill in your actual values

# ============================================================================
# Auth0 Configuration
# ============================================================================
# Get these values from your Auth0 Application settings:
# https://manage.auth0.com/dashboard/{region}/{tenant}/applications

# Auth0 tenant domain (without https://)
AUTH0_DOMAIN=https://your-tenant.auth0.com

# Auth0 Application Client ID
AUTH0_CLIENT_ID=your-client-id-here

# Auth0 Application Client Secret
AUTH0_CLIENT_SECRET=your-client-secret-here

# ============================================================================
# Database Configuration
# ============================================================================
# REQUIRED: Set a strong password for PostgreSQL
# Never use default/weak passwords like "password" or "123456"
POSTGRES_PASSWORD=your-secure-password-here

# Optional overrides (uncomment if needed):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=humanrsc
# POSTGRES_USER=postgres

# ============================================================================
# Application Configuration
# ============================================================================
# HTTP port for backend service (default: 8080)
# HTTP_PORT=8080

# Log level (TRACE, DEBUG, INFO, WARN, ERROR)
# LOG_LEVEL=INFO

# Enable JSON logging (true for production, false for development)
# LOG_JSON=false

# ============================================================================
# Notes:
# ============================================================================
# - Never commit the actual .env file to version control
# - Use AWS Secrets Manager or similar for production secrets
# - Auth0 configuration can be found in your Auth0 Dashboard
# - For multi-tenant setup, tenant ID is extracted from JWT claims
